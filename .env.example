# Copy this file to ".env" and fill in the values from your JSONBin.io account.
# Never commit the real ".env" file — it's already in .gitignore.

# The Bin ID shown on your bin's page/dashboard.
VITE_JSONBIN_BIN_ID=

# A scoped Access Key (NOT your Master Key) with Read + Update permission
# limited to this one bin. See README.md for how to create one.
# If your key contains "$", wrap it in single quotes so it is not expanded.
VITE_JSONBIN_ACCESS_KEY='$2a$10...'

# Single login credentials for the app. Put your real values in your local .env file.
VITE_CRICKTRACK_USERNAME=
VITE_CRICKTRACK_PASSWORD=
